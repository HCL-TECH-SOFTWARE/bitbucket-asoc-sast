wss.url=https://saas.whitesourcesoftware.com/agent
# apiKey is provided via -apiKey parameter in the workflow

##################################
# Product section
##################################
productName=AppScan_BitBucket

##################################
# Project section
##################################
projectName=2.0.0-Linux

#########################################################################################
# Includes/Excludes Glob patterns - PLEASE USE ONLY ONE EXCLUDE LINE AND ONE INCLUDE LINE
#########################################################################################
includes=**/**
case.sensitive.glob=false
followSymbolicLinks=true
excludes=**/__pycache__ **/*.pyc **/*.pyo **/.venv **/.env **/venv **/env **/*.egg-info **/dist **/build **/.pytest_cache **/.mypy_cache **/*.log **/*.tmp

##########################################
# General Scan settings
##########################################
checkPolicies=false
forceCheckAllDependencies=false
offline=false

##################################
# Archive properties
##################################
archiveExtractionDepth=2
archiveIncludes=**/*.zip **/*.tar **/*.tar.gz **/*.tgz **/*.whl

##########################################
# Docker Image Scanning
# Scans the built Linux container image for vulnerable OS packages and pip dependencies
##########################################
docker.scanImages=true
docker.pull=false
docker.excludes=
docker.projectNameFormat=projectName

##########################################
# Python / pip
##########################################
python.resolveDependencies=true
python.ignoreSourceFiles=true
python.runPipenvPreStep=false
python.pipenvDevDependencies=false
python.resolveHierarchyTree=true

pip.resolveDependencies=true
pip.includeIndirectDependencies=true
pip.ignoreSourceFiles=true
pip.requirementsFileIncludes=requirements.txt
