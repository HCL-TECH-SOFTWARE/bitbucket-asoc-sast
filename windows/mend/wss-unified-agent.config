####################################################################
# WhiteSource Unified-Agent configuration file
####################################################################
#REM# means in original version
##################################
# Organization tokens:
##################################
# Change the below URL to your WhiteSource server.
# Use the 'WhiteSource Server URL' which can be retrieved
# from your 'Profile' page on the 'Server URLs' panel.
# Then, add the '/agent' path to it.
# example: wss.url=https://saas.whitesourcesoftware.com/agent
wss.url=https://saas.whitesourcesoftware.com/agent
#wss.connectionTimeoutMinutes=60
apiKey=fceb37eb-3ffc-4f2b-b80e-bd5e865d9a40

#userKey is required if WhiteSource administrator has enabled "Enforce user level access" option
#userKey=

##################################
# Product section
##################################
productName=AppScan_Test
#productToken=PRODUCTS_TOKEN
#productVersion=<currently disabled>

##################################
# Project section
##################################
projectName=2.0.0-windows
#projectToken=PROJECTS_TOKEN
#projectVersion=<currently disabled>
#projectPerFolder=true
#projectPerFolderIncludes=
#projectPerFolderExcludes=

#updateType=APPEND
#requesterEmail=user@provider.com

#########################################################################################
# Includes/Excludes Glob patterns - PLEASE USE ONLY ONE EXCLUDE LINE AND ONE INCLUDE LINE
#########################################################################################
#includes=*
#REM#includes=**/*.c **/*.cc **/*.cp **/*.cpp **/*.cxx **/*.c++ **/*.h **/*.hpp **/*.hxx
#includes=**/*.m **/*.mm  **/*.js **/*.php
#includes=**/*.jar
#includes=**/*.gem **/*.rb
#includes=**/*.dll **/*.cs **/*.nupkg
#includes=**/*.tgz **/*.deb **/*.gzip **/*.rpm **/*.tar.bz2
#includes=**/*.zip **/*.tar.gz **/*.egg **/*.whl **/*.py

## Exclude file extensions or specific directories by adding **/*.<extension> or **/<excluded_dir>/**
excludes=**/*.apk 
#REM#excludes=**/*sources.jar **/*javadoc.jar

case.sensitive.glob=false
followSymbolicLinks=true

##########################################
# General Scan settings
##########################################
checkPolicies=false
forceCheckAllDependencies=false
#forceUpdate=false
#forceUpdate.failBuildOnPolicyViolation=false
offline=false
#ignoreSourceFiles=true
#scanComment=
#updateInventory=false
#resolveAllDependencies=false
#failErrorLevel=ALL
#requireKnownSha1=false
#generateProjectDetailsJson=true
#generateScanReport=true
#scanReportTimeoutMinutes=10
#scanReportFilenameFormat=
#excludeDependenciesFromNodes=.*commons-io.*,.*maven-model

#analyzeFrameworks=true
#analyzeFrameworksReference=

##################################
# Archive properties
##################################
#archiveExtractionDepth=7
#archiveIncludes=**/*.zip **/*.jar **/*.vsix **/*.war **/*.ear
#archiveExcludes=PRODUCTS_ARCHIVEEXCLUDES
#REM#archiveExtractionDepth=2
#REM#archiveIncludes=**/*.war **/*.ear
#REM#archiveExcludes=**/*sources.jar

##########################################
